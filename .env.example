# Supabase project credentials for syncing the offline marketing vault.
# Copy to .env locally and fill values from Supabase Project Settings > API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Optional overrides
OFFLINE_MARKETING_VAULT=offline-marketing-graph
SUPABASE_SCHEMA=public
DASHBOARD_PORT=4321
